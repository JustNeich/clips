# Production/Preview bootstrap secret.
# Required on Vercel because NODE_ENV=production there.
APP_BOOTSTRAP_SECRET=change-me

# Required if you use YouTube publishing/OAuth credential storage in production.
# Prefer a stable 32-byte base64 key, for example: openssl rand -base64 32
# APP_ENCRYPTION_KEY=

# Optional writable storage overrides.
# Useful on serverless runtimes if you want to override the default Vercel /tmp fallback.
# On Render Docker deploys the app defaults to /var/data/app and /var/data/codex-sessions.
# APP_DATA_DIR=/tmp/clips-automations-data
# CODEX_SESSIONS_DIR=/tmp/clips-automations-codex-sessions

# Optional yt-dlp authentication for YouTube anti-bot pages.
# Use either a path to Netscape cookies.txt on the server:
# YTDLP_COOKIES_PATH=/var/data/yt-dlp/cookies.txt
# Or paste the full cookies.txt contents directly:
# YTDLP_COOKIES=

# Recommended primary comments path for public YouTube videos/shorts.
# Server-side key for YouTube Data API v3.
# YOUTUBE_DATA_API_KEY=

# Required for YouTube channel connect/publishing.
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# Optional Visolix hosted source provider.
# Supports direct download jobs for YouTube / Instagram / Facebook / TikTok.
# VISOLIX_API_KEY=
# VISOLIX_BASE_URL=https://developers.visolix.com
# VISOLIX_YOUTUBE_FORMAT=720

# Optional Codex tuning.
CODEX_STAGE2_MODEL=gpt-5.4
CODEX_STAGE2_REASONING_EFFORT=xhigh
CODEX_STAGE2_TIMEOUT_MS=120000
CODEX_STAGE2_DESCRIPTION_MODEL=gpt-5.2
CODEX_STAGE2_DESCRIPTION_REASONING_EFFORT=medium
CODEX_STAGE2_DESCRIPTION_TIMEOUT_MS=90000
CODEX_STAGE3_MODEL=gpt-5.2
CODEX_STAGE3_REASONING_EFFORT=xhigh
CODEX_STAGE3_TIMEOUT_MS=120000
REMOTION_RENDER_TIMEOUT_MS=180000
STAGE3_DEFAULT_EXECUTION_TARGET=local
STAGE3_ALLOW_HOST_EXECUTION=0
STAGE3_WORKER_PAIRING_TTL_SEC=600
STAGE3_WORKER_SESSION_TTL_SEC=2592000
# Optional explicit public origin for worker bootstrap commands.
# Useful if your proxy/runtime reports request.url as 0.0.0.0 or another internal host.
# PUBLIC_APP_ORIGIN=https://clips-vy11.onrender.com

# Local-only. Do not use this macOS path on Vercel.
# CODEX_BIN=/Applications/Codex.app/Contents/Resources/codex

# Render Docker default.
# CODEX_BIN=/usr/local/bin/codex
