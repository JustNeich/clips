# Production/Preview bootstrap secret.
# Required on Vercel because NODE_ENV=production there.
APP_BOOTSTRAP_SECRET=change-me

# Required if you use YouTube publishing/OAuth credential storage in production.
# Prefer a stable 32-byte base64 key, for example: openssl rand -base64 32
# APP_ENCRYPTION_KEY=

# Optional writable storage overrides.
# Useful on serverless runtimes if you want to override the default Vercel /tmp fallback.
# On Render Docker deploys the app defaults to /var/data/app and /var/data/codex-sessions.
# APP_DATA_DIR=/tmp/clips-automations-data
# CODEX_SESSIONS_DIR=/tmp/clips-automations-codex-sessions

# Optional yt-dlp authentication for YouTube anti-bot pages.
# Use either a path to Netscape cookies.txt on the server:
# YTDLP_COOKIES_PATH=/var/data/yt-dlp/cookies.txt
# Or paste the full cookies.txt contents directly:
# YTDLP_COOKIES=

# Recommended primary comments path for public YouTube videos/shorts.
# Server-side key for YouTube Data API v3.
# YOUTUBE_DATA_API_KEY=

# Required for YouTube channel connect/publishing.
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# Optional replacement for GOOGLE_OAUTH_CLIENT_ID / GOOGLE_OAUTH_CLIENT_SECRET
# when YouTube publishing must be split across multiple Google API projects.
# YOUTUBE_OAUTH_CLIENTS_JSON=[{"key":"primary","label":"Clips API Project 1","projectNumber":"122834058966","clientId":"...apps.googleusercontent.com","clientSecret":"...","dailyUploadBudget":8},{"key":"secondary","label":"Clips API Project 2","projectNumber":"123456789012","clientId":"...apps.googleusercontent.com","clientSecret":"...","dailyUploadBudget":8}]
# YOUTUBE_OAUTH_DEFAULT_CLIENT_KEY=primary

# Optional Visolix hosted source provider.
# Supports direct download jobs for YouTube / Instagram / Facebook / TikTok.
# VISOLIX_API_KEY=
# VISOLIX_BASE_URL=https://developers.visolix.com
# VISOLIX_YOUTUBE_FORMAT=720

# Optional Codex tuning.
CODEX_STAGE2_MODEL=gpt-5.4
CODEX_STAGE2_REASONING_EFFORT=xhigh
CODEX_STAGE2_TIMEOUT_MS=120000
CODEX_STAGE2_DESCRIPTION_MODEL=gpt-5.2
CODEX_STAGE2_DESCRIPTION_REASONING_EFFORT=medium
CODEX_STAGE2_DESCRIPTION_TIMEOUT_MS=90000
CODEX_STAGE3_MODEL=gpt-5.2
CODEX_STAGE3_REASONING_EFFORT=xhigh
CODEX_STAGE3_TIMEOUT_MS=120000
REMOTION_RENDER_TIMEOUT_MS=180000
STAGE3_DEFAULT_EXECUTION_TARGET=local
STAGE3_ALLOW_HOST_EXECUTION=0
STAGE3_WORKER_PAIRING_TTL_SEC=600
STAGE3_WORKER_SESSION_TTL_SEC=2592000
# Optional explicit public origin for worker bootstrap commands.
# Useful if your proxy/runtime reports request.url as 0.0.0.0 or another internal host.
# PUBLIC_APP_ORIGIN=https://clips-vy11.onrender.com

# Project Kings portfolio background runtime. Keep disabled until the frozen manifest
# contains benchmark-qualified selections for all six semantic
# roles. Revision is a deterministic durable job and has no model route.
# PORTFOLIO_PIPELINE_V1_ENABLED=0
# Explicit live 3x3 rollout without the first-item public canary. Keep disabled by default.
# PORTFOLIO_PIPELINE_POST_CANARY_ENABLED=0
# PORTFOLIO_PIPELINE_ROUTE_MANIFEST_PATH=docs/project-kings-production-pipeline-v1/evidence/project-kings-model-routes-v4.json

# Local MCP clients only. Store real values in ~/.config/assistant/clips-mcp.env with chmod 600.
# CLIPS_APP_URL=https://clips-vy11.onrender.com
# CLIPS_MCP_TOKEN=clips_machine_...
# CLIPS_MCP_ENV_FILE=/Users/neichyabazhi/.config/assistant/clips-mcp.env

# Mac mini/Zoro remote Project Kings daemon. Keep secrets in the MCP env file;
# the daemon talks only to the production owner API and never opens local APP_DATA_DIR.
# PROJECT_KINGS_PORTFOLIO_ARMED=0
# PROJECT_KINGS_PORTFOLIO_MODE=shadow
# PROJECT_KINGS_PORTFOLIO_CANARY_POLICY=none
# PROJECT_KINGS_PORTFOLIO_PROFILE_IDS=dark_profile_id,light_profile_id,cop_profile_id
# PROJECT_KINGS_PORTFOLIO_TIMEZONE=Europe/Moscow
# PROJECT_KINGS_PORTFOLIO_POLL_INTERVAL_MS=30000
# PROJECT_KINGS_PORTFOLIO_HTTP_TIMEOUT_MS=15000
# PROJECT_KINGS_PORTFOLIO_BLOCKED_BACKOFF_MS=300000
# PROJECT_KINGS_PORTFOLIO_STATE_DIR=/Users/neichyabazhi/Library/Application Support/com.zoro.clips-project-kings-portfolio
# PROJECT_KINGS_PORTFOLIO_KILL_SWITCH_PATH=/Users/neichyabazhi/Library/Application Support/com.zoro.clips-project-kings-portfolio/DISABLED

# Separate Project Kings autonomous source-refill config (stored in
# ~/.config/assistant/project-kings-source-buffer-refiller.env with chmod 600).
# The default command is dry-run; shadow performs discovery/qualification but
# never uploads. Execute additionally requires the env gate below and the CLI's
# explicit --allow-upload. No frozen readiness catalog is used by this contour.
# PORTFOLIO_PIPELINE_ROUTE_MANIFEST_PATH=docs/project-kings-production-pipeline-v1/evidence/project-kings-model-routes-v4.json
# PROJECT_KINGS_SOURCE_BUFFER_REFILLER_STATE_DIR=/Users/neichyabazhi/Library/Application Support/com.zoro.clips-project-kings-source-buffer-refiller
# PROJECT_KINGS_CLIPS_CDP_ORIGIN=http://127.0.0.1:52376
# PROJECT_KINGS_SOURCE_REFILL_WHISPER_MODEL=tiny
# PROJECT_KINGS_SOURCE_REFILL_UPLOAD_ARMED=0

# Local-only. Do not use this macOS path on Vercel.
# CODEX_BIN=/Applications/Codex.app/Contents/Resources/codex

# Render Docker default.
# CODEX_BIN=/usr/local/bin/codex
