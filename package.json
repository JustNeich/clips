{
  "name": "clips-downloader",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "node --no-warnings ./node_modules/next/dist/bin/next dev",
    "prebuild": "npm run build:stage3-worker",
    "build:stage3-worker": "node scripts/build-stage3-worker.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "stage3-worker": "tsx apps/stage3-worker/index.ts"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "@remotion/bundler": "^4.0.432",
    "@remotion/renderer": "^4.0.432",
    "next": "^15.5.9",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "remotion": "^4.0.432"
  },
  "devDependencies": {
    "@remotion/cli": "^4.0.432",
    "@types/node": "22.10.2",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "esbuild": "^0.25.0",
    "tsx": "^4.20.6",
    "typescript": "5.7.2"
  }
}
