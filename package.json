{
  "name": "clips-downloader",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "clean:next": "node -e \"try{require('node:fs').rmSync('.next',{recursive:true,force:true})}catch{};try{require('node:fs').unlinkSync('tsconfig.tsbuildinfo')}catch{}\"",
    "clean:typegen": "node -e \"try{require('node:fs').rmSync('.next/types',{recursive:true,force:true})}catch{};try{require('node:fs').unlinkSync('tsconfig.tsbuildinfo')}catch{}\"",
    "dev": "node --no-warnings ./node_modules/next/dist/bin/next dev",
    "dev:prod-api": "CLIPS_REMOTE_API_ORIGIN=https://clips-vy11.onrender.com node --no-warnings ./node_modules/next/dist/bin/next dev",
    "prebuild": "npm run clean:next && npm run build:stage3-worker && npm run build:stage3-host-render-child",
    "build:stage3-worker": "node scripts/build-stage3-worker.mjs",
    "build:project-kings-semantic-worker": "node scripts/build-project-kings-semantic-worker.mjs",
    "build:stage3-host-render-child": "node scripts/build-stage3-host-render-child.mjs",
    "build:desktop-worker": "node scripts/build-desktop-worker.mjs",
    "dist:desktop-worker": "npm run build:stage3-worker && npm run build:desktop-worker && electron-builder --config electron-builder.desktop.json",
    "desktop-worker:dev": "npm run build:desktop-worker && electron output/desktop-worker/main.cjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "npm run clean:typegen && next typegen && tsc --noEmit --incremental false",
    "test:montage-learning": "node --import tsx --test --test-concurrency=1 tests/montage-learning.test.ts",
    "test:stage2": "node --import tsx --test --test-concurrency=1 tests/viral-shorts-worker.test.ts tests/channel-learning-onboarding.test.ts tests/stage2-banned-words.test.ts",
    "test:viral-worker": "node --import tsx --test --test-concurrency=1 tests/viral-shorts-worker.test.ts",
    "mcp:flows": "tsx scripts/clips-flow-mcp.ts",
    "mcp:control": "tsx scripts/clips-control-mcp.ts",
    "mcp:owner": "tsx scripts/clips-owner-mcp.ts",
    "project-kings:portfolio-daemon": "node scripts/run-project-kings-portfolio-daemon.mjs run",
    "project-kings:portfolio-daemon:tick": "node scripts/run-project-kings-portfolio-daemon.mjs tick",
    "project-kings:source-buffer-refiller": "node --import tsx scripts/run-project-kings-autonomous-source-refill.mts --mode dry_run",
    "project-kings:source-buffer-refiller:shadow": "node --import tsx scripts/run-project-kings-autonomous-source-refill.mts --mode shadow",
    "project-kings:source-buffer-refiller:execute": "node --import tsx scripts/run-project-kings-autonomous-source-refill.mts --mode execute --allow-upload",
    "project-kings:source-buffer-refiller:legacy-frozen": "node scripts/run-project-kings-source-buffer-refiller.mjs tick",
    "project-kings:source-buffer:sync": "node scripts/sync-project-kings-source-buffer.mjs",
    "project-kings:source-buffer:audit": "node --import tsx scripts/audit-project-kings-source-buffer.mts",
    "project-kings:source-policy:replay": "node --import tsx scripts/replay-project-kings-source-policy-benchmark.mts",
    "project-kings:source-policy:catalog-rerun": "node --import tsx scripts/run-project-kings-catalog-source-policy.mts",
    "project-kings:source-fit:attest": "node --import tsx scripts/run-project-kings-source-fit-attestations.mts",
    "project-kings:instagram:discover": "node --import tsx scripts/discover-project-kings-instagram-donors.ts",
    "project-kings:models:benchmark": "node --import tsx scripts/run-project-kings-model-benchmarks.ts",
    "project-kings:models:freeze": "node --import tsx scripts/freeze-project-kings-model-route-manifest.mts",
    "project-kings:profiles:freeze": "node --import tsx scripts/freeze-project-kings-production-profiles.mts",
    "project-kings:replays": "node --import tsx scripts/run-project-kings-replays.mts",
    "project-kings:qa:corpus": "node --import tsx scripts/build-project-kings-vision-qa-corpus.mts",
    "project-kings:qa:defects": "node --import tsx scripts/generate-project-kings-vision-qa-defects.mts",
    "project-kings:qa:annotations": "node --import tsx scripts/prepare-project-kings-vision-qa-annotations.mts",
    "project-kings:qa:judge": "node --import tsx scripts/run-project-kings-isolated-vision-qa-judge.mts",
    "project-kings:migration:rehearse": "node --import tsx scripts/rehearse-project-kings-db-migration.mts",
    "project-kings:release:freeze": "node --import tsx scripts/freeze-project-kings-production-release.mts",
    "project-kings:launchd:plan": "node scripts/install-project-kings-portfolio-launchd.mjs --dry-run",
    "project-kings:launchd:install": "node scripts/install-project-kings-portfolio-launchd.mjs --install",
    "project-kings:semantic-worker:plan": "node scripts/install-project-kings-semantic-worker-launchd.mjs --dry-run",
    "project-kings:semantic-worker:pair": "node scripts/pair-project-kings-semantic-worker.mjs",
    "project-kings:semantic-worker:install": "node scripts/install-project-kings-semantic-worker-launchd.mjs --install",
    "project-kings:semantic-worker:rollback": "node scripts/install-project-kings-semantic-worker-launchd.mjs --rollback",
    "project-kings:source-buffer-launchd:plan": "node scripts/install-project-kings-source-buffer-refiller-launchd.mjs --dry-run",
    "project-kings:source-buffer-launchd:install": "node scripts/install-project-kings-source-buffer-refiller-launchd.mjs --install",
    "montage-learning:export": "tsx scripts/montage-learning-export.ts",
    "macmini:healthcheck": "node scripts/clips-macmini-healthcheck.mjs",
    "market:stats-refresh": "node scripts/market-stats-refresh.mjs",
    "copscopes:daily-production": "node scripts/run-copscopes-daily-production.mjs",
    "stage2-worker": "tsx scripts/viral-shorts-worker.ts",
    "stage3-worker": "tsx apps/stage3-worker/index.ts",
    "ghostface:apply-template": "tsx scripts/apply-ghostface-country-channel-template.ts",
    "design:template:import": "tsx scripts/template-import-figma.ts",
    "design:template:capture": "tsx scripts/template-calibration-capture.ts",
    "design:template:batch": "tsx scripts/template-calibration-batch.ts",
    "design:template:percy": "percy exec -- tsx scripts/template-calibration-percy.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@node-rs/argon2": "^2.0.2",
    "@remotion/bundler": "^4.0.432",
    "@remotion/renderer": "^4.0.432",
    "next": "^15.5.14",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "remotion": "^4.0.432",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@percy/cli": "^1.31.9",
    "@percy/playwright": "^1.0.10",
    "@playwright/test": "^1.58.2",
    "@remotion/cli": "^4.0.432",
    "@types/node": "22.10.2",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.25.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.14",
    "html-to-image": "^1.11.13",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "tsx": "^4.20.6",
    "typescript": "5.7.2"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
